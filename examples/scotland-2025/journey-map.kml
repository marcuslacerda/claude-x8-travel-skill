<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Scotland 2025 — The travelers</name>
    <description>Road trip 18 Jun – 28 Jun 2025 (Days 7-17 da viagem completa Londres+Escócia). Pickup do carro: Edinburgh Airport. Devolução: Edinburgh. Distância total dirigida: ~1.250 km (£105 em gasolina). Drive times retroativamente validados via Google Maps Directions API.</description>

    <!-- ========== ICON STYLES ========== -->
    <Style id="start-end">
      <IconStyle><scale>1.3</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/grn-stars.png</href></Icon></IconStyle>
    </Style>
    <Style id="basecamp">
      <IconStyle><scale>1.0</scale><Icon><href>http://maps.google.com/mapfiles/kml/shapes/campground.png</href></Icon></IconStyle>
    </Style>
    <Style id="castelo">
      <IconStyle><scale>1.2</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/purple-diamond.png</href></Icon></IconStyle>
    </Style>
    <Style id="natureza">
      <IconStyle><scale>1.1</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/grn-blank.png</href></Icon></IconStyle>
    </Style>
    <Style id="trekking">
      <IconStyle><scale>1.2</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/orange-circle.png</href></Icon></IconStyle>
    </Style>
    <Style id="lago">
      <IconStyle><scale>1.1</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/ltblu-circle.png</href></Icon></IconStyle>
    </Style>
    <Style id="viewpoint">
      <IconStyle><scale>1.0</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/wht-stars.png</href></Icon></IconStyle>
    </Style>
    <Style id="scenic">
      <IconStyle><scale>1.1</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/ylw-stars.png</href></Icon></IconStyle>
    </Style>
    <Style id="vila">
      <IconStyle><scale>1.1</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/red-diamond.png</href></Icon></IconStyle>
    </Style>
    <Style id="waterfall">
      <IconStyle><scale>1.0</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/ltblu-stars.png</href></Icon></IconStyle>
    </Style>
    <Style id="memorial">
      <IconStyle><scale>0.9</scale><Icon><href>http://maps.google.com/mapfiles/kml/paddle/wht-blank.png</href></Icon></IconStyle>
    </Style>

    <!-- ========== ROUTE STYLES — per day ========== -->
    <!-- KML colors: aaBBGGRR format -->
    <Style id="route-day7"><LineStyle><color>cc228844</color><width>4</width></LineStyle></Style>
    <Style id="route-day8"><LineStyle><color>cc8B4789</color><width>3</width></LineStyle></Style>
    <Style id="route-day9"><LineStyle><color>cc2E8B57</color><width>4</width></LineStyle></Style>
    <Style id="route-day10"><LineStyle><color>ccB05F00</color><width>3</width></LineStyle></Style>
    <Style id="route-day11"><LineStyle><color>cc4682B4</color><width>4</width></LineStyle></Style>
    <Style id="route-day12"><LineStyle><color>ccFF8800</color><width>3</width></LineStyle></Style>
    <Style id="route-day13"><LineStyle><color>ccD2691E</color><width>4</width></LineStyle></Style>
    <Style id="route-day15"><LineStyle><color>ccC71585</color><width>4</width></LineStyle></Style>
    <Style id="route-day17"><LineStyle><color>ccFFAA00</color><width>4</width></LineStyle></Style>

    <!-- ============================================ -->
    <!-- PONTOS DE INTERESSE — All Placemarks         -->
    <!-- ============================================ -->
    <Folder>
      <name>Pontos de Interesse</name>

      <!-- Day 7: London → Edinburgh → Aberdeen -->
      <Placemark>
        <name>Edinburgh Airport (pickup do carro)</name>
        <styleUrl>#start-end</styleUrl>
        <description>Day 7 (18 Jun) — Sixt rental, start dos 1.250 km na Escócia.</description>
        <Point><coordinates>-3.3608,55.9472,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Aberdeen — base 1</name>
        <styleUrl>#basecamp</styleUrl>
        <description>Day 7-8 (18-19 Jun) — 2 noites. Hospedagem £202.</description>
        <Point><coordinates>-2.1032,57.1443,0</coordinates></Point>
      </Placemark>

      <!-- Day 8: Dunnottar &amp; Glamis Castle -->
      <Placemark>
        <name>Dunnottar Castle</name>
        <styleUrl>#castelo</styleUrl>
        <description>Day 8 (19 Jun) — Castelo à beira-mar em Stonehaven. 25min/30km de Aberdeen.</description>
        <Point><coordinates>-2.1971,56.9461,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Glamis Castle</name>
        <styleUrl>#castelo</styleUrl>
        <description>Day 8 (19 Jun) — Séc. XVII, berço da Rainha Mãe. 47min/67km de Dunnottar.</description>
        <Point><coordinates>-3.0017,56.6202,0</coordinates></Point>
      </Placemark>

      <!-- Day 9: Aberdeen → Inverness via Cairngorms -->
      <Placemark>
        <name>Ballater (Royal Deeside)</name>
        <styleUrl>#vila</styleUrl>
        <description>Day 9 (20 Jun) — Aldeia real no caminho via A93.</description>
        <Point><coordinates>-3.0366,57.0500,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Loch An Eilein — Cairngorms NP</name>
        <styleUrl>#lago</styleUrl>
        <description>Day 9 (20 Jun) — Castelo em ruínas no meio do lago. Trail de Rothiemurchus.</description>
        <Point><coordinates>-3.6066,57.0607,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Drumnadrochit — base 2</name>
        <styleUrl>#basecamp</styleUrl>
        <description>Day 9-10 (20-21 Jun) — 2 noites com vista pra Urquhart. Hospedagem £337.</description>
        <Point><coordinates>-4.4790,57.3345,0</coordinates></Point>
      </Placemark>

      <!-- Day 10: Beauly, Cawdor &amp; Urquhart -->
      <Placemark>
        <name>Beauly Priory</name>
        <styleUrl>#castelo</styleUrl>
        <description>Day 10 (21 Jun) — Mosteiro do séc. XIII. Locação Outlander.</description>
        <Point><coordinates>-4.4578,57.4846,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Cawdor Castle</name>
        <styleUrl>#castelo</styleUrl>
        <description>Day 10 (21 Jun) — Lenda de Macbeth, séc. XIV. 45min/48km de Drumnadrochit.</description>
        <Point><coordinates>-3.9265,57.5241,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Urquhart Castle (Loch Ness sunset)</name>
        <styleUrl>#castelo</styleUrl>
        <description>Day 10 (21 Jun) — Ruínas à beira do Loch Ness ao pôr do sol.</description>
        <Point><coordinates>-4.4420,57.3241,0</coordinates></Point>
      </Placemark>

      <!-- Day 11: Drumnadrochit → Skye -->
      <Placemark>
        <name>Eilean Donan Castle</name>
        <styleUrl>#castelo</styleUrl>
        <description>Day 11 (22 Jun) — Um dos castelos mais bonitos da Escócia. Lazer £160.</description>
        <Point><coordinates>-5.5162,57.2739,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Inverinate — base 3</name>
        <styleUrl>#basecamp</styleUrl>
        <description>Day 11-12 (22-23 Jun) — 2 noites em Skye. Hospedagem £375. Jantar romântico.</description>
        <Point><coordinates>-5.4553,57.2408,0</coordinates></Point>
      </Placemark>

      <!-- Day 12: Skye loop -->
      <Placemark>
        <name>Old Man of Storr</name>
        <styleUrl>#trekking</styleUrl>
        <description>Day 12 (23 Jun) — Pináculo rochoso icônico, trail clássico de Skye.</description>
        <Point><coordinates>-6.1831,57.5071,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Kilt Rock &amp; Mealt Falls</name>
        <styleUrl>#viewpoint</styleUrl>
        <description>Day 12 (23 Jun) — Penhasco basáltico com cachoeira caindo no mar.</description>
        <Point><coordinates>-6.1727,57.6113,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Quiraing</name>
        <styleUrl>#trekking</styleUrl>
        <description>Day 12 (23 Jun) — Formações rochosas dramáticas no norte de Trotternish.</description>
        <Point><coordinates>-6.2653,57.6436,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Fairy Glen (Uig)</name>
        <styleUrl>#scenic</styleUrl>
        <description>Day 12 (23 Jun) — Mini-paisagem de morrinhos coniformes, visual de conto de fadas.</description>
        <Point><coordinates>-6.3249,57.5824,0</coordinates></Point>
      </Placemark>

      <!-- Day 13: Skye → Glencoe via Glenfinnan -->
      <Placemark>
        <name>Glen Shiel — Five Sisters of Kintail</name>
        <styleUrl>#viewpoint</styleUrl>
        <description>Day 13 (24 Jun) — Cinco picos icônicos das Highlands a oeste.</description>
        <Point><coordinates>-5.3667,57.1667,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Glenfinnan Viaduct</name>
        <styleUrl>#memorial</styleUrl>
        <description>Day 13 (24 Jun) — Viaduto da Hogwarts Express. Monumento Jacobita ao lado (Outlander).</description>
        <Point><coordinates>-5.4318,56.8762,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Fort William — base 4</name>
        <styleUrl>#basecamp</styleUrl>
        <description>Day 13-14 (24-25 Jun) — 2 noites. Hospedagem Glencoe/Fort William £269.</description>
        <Point><coordinates>-5.1052,56.8198,0</coordinates></Point>
      </Placemark>

      <!-- Day 14: Ben Nevis &amp; Steall Falls -->
      <Placemark>
        <name>Ben Nevis (beginner track)</name>
        <styleUrl>#trekking</styleUrl>
        <description>Day 14 (25 Jun) — Pico mais alto do Reino Unido (1.345m). Track principal: 3h ida.</description>
        <Point><coordinates>-5.0036,56.7969,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Steall Falls (Glen Nevis)</name>
        <styleUrl>#waterfall</styleUrl>
        <description>Day 14 (25 Jun) — Cachoeira em Glen Nevis, cenário do Quidditch em Hogwarts.</description>
        <Point><coordinates>-5.0007,56.7775,0</coordinates></Point>
      </Placemark>

      <!-- Day 15: Glencoe → Linlithgow -->
      <Placemark>
        <name>Three Sisters of Glencoe</name>
        <styleUrl>#viewpoint</styleUrl>
        <description>Day 15 (26 Jun) — Três picos icônicos em Glencoe (007 Skyfall).</description>
        <Point><coordinates>-4.9943,56.6593,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Doune Castle (Castle Leoch)</name>
        <styleUrl>#castelo</styleUrl>
        <description>Day 15 (26 Jun) — Castle Leoch da série Outlander. Também Game of Thrones e Monty Python.</description>
        <Point><coordinates>-4.0499,56.1852,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Stirling Castle</name>
        <styleUrl>#castelo</styleUrl>
        <description>Day 15 (26 Jun) — Um dos castelos mais importantes da Escócia.</description>
        <Point><coordinates>-3.9456,56.1229,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>National Wallace Monument</name>
        <styleUrl>#memorial</styleUrl>
        <description>Day 15 (26 Jun) — Monumento a William Wallace em Stirling.</description>
        <Point><coordinates>-3.9179,56.1388,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Linlithgow — base 5</name>
        <styleUrl>#basecamp</styleUrl>
        <description>Day 15-16 (26-27 Jun) — 2 noites no Court Residence. Hospedagem £336.</description>
        <Point><coordinates>-3.6008,55.9789,0</coordinates></Point>
      </Placemark>

      <!-- Day 16: Linlithgow Palace day -->
      <Placemark>
        <name>Linlithgow Palace</name>
        <styleUrl>#castelo</styleUrl>
        <description>Day 16 (27 Jun) — Berço de Mary Queen of Scots. Igreja St. Michael's (séc. XV) ao lado.</description>
        <Point><coordinates>-3.6008,55.9789,0</coordinates></Point>
      </Placemark>

      <!-- Day 17: Linlithgow → Edinburgh -->
      <Placemark>
        <name>Blackness Castle</name>
        <styleUrl>#castelo</styleUrl>
        <description>Day 17 (28 Jun) — Forte do séc. XV à beira do Firth of Forth. Black Jack Randall's Fort William na série Outlander.</description>
        <Point><coordinates>-3.5161,56.0060,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Hopetoun House</name>
        <styleUrl>#castelo</styleUrl>
        <description>Day 17 (28 Jun) — Country house do séc. XVII, Versailles escocês.</description>
        <Point><coordinates>-3.4626,55.9956,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Edinburgh Castle — base 6</name>
        <styleUrl>#basecamp</styleUrl>
        <description>Day 17-18 (28-29 Jun) — 2 noites. Hospedagem Premier Inn £356.</description>
        <Point><coordinates>-3.1999,55.9486,0</coordinates></Point>
      </Placemark>
    </Folder>

    <!-- ============================================ -->
    <!-- ROTAS — Daily LineStrings                    -->
    <!-- ============================================ -->
    <Folder>
      <name>Rotas</name>

      <Placemark>
        <name>Day 7: Edinburgh Airport → Aberdeen (via Dundee)</name>
        <styleUrl>#route-day7</styleUrl>
        <description>2h22 / 201km via M90 + A90 (Google Maps).</description>
        <LineString>
          <tessellate>1</tessellate>
          <coordinates>
            -3.3608,55.9472,0
            -3.4174,55.9546,0
            -3.4001,56.3864,0
            -3.0631,56.4647,0
            -2.9501,56.4946,0
            -2.2087,56.9766,0
            -2.1032,57.1443,0
          </coordinates>
        </LineString>
      </Placemark>

      <Placemark>
        <name>Day 8: Aberdeen → Dunnottar → Glamis → Aberdeen</name>
        <styleUrl>#route-day8</styleUrl>
        <description>Loop costeiro ~3h.</description>
        <LineString>
          <tessellate>1</tessellate>
          <coordinates>
            -2.1032,57.1443,0
            -2.1971,56.9461,0
            -3.0017,56.6202,0
            -2.1032,57.1443,0
          </coordinates>
        </LineString>
      </Placemark>

      <Placemark>
        <name>Day 9: Aberdeen → Cairngorms → Drumnadrochit</name>
        <styleUrl>#route-day9</styleUrl>
        <description>~3h30 / 230km via Ballater (cênica). Alternativa direta A96: 2h40 / 191km.</description>
        <LineString>
          <tessellate>1</tessellate>
          <coordinates>
            -2.1032,57.1443,0
            -3.0366,57.0500,0
            -3.6066,57.0607,0
            -4.4790,57.3345,0
          </coordinates>
        </LineString>
      </Placemark>

      <Placemark>
        <name>Day 10: Drumnadrochit → Beauly → Cawdor → Urquhart → Drumnadrochit</name>
        <styleUrl>#route-day10</styleUrl>
        <description>Loop dos castelos.</description>
        <LineString>
          <tessellate>1</tessellate>
          <coordinates>
            -4.4790,57.3345,0
            -4.4578,57.4846,0
            -3.9265,57.5241,0
            -4.4420,57.3241,0
            -4.4790,57.3345,0
          </coordinates>
        </LineString>
      </Placemark>

      <Placemark>
        <name>Day 11: Drumnadrochit → Inverinate (via Eilean Donan)</name>
        <styleUrl>#route-day11</styleUrl>
        <description>1h09 / 84km via A887 + A87.</description>
        <LineString>
          <tessellate>1</tessellate>
          <coordinates>
            -4.4790,57.3345,0
            -4.9585,57.1461,0
            -5.5162,57.2739,0
            -5.4553,57.2408,0
          </coordinates>
        </LineString>
      </Placemark>

      <Placemark>
        <name>Day 12: Skye loop (Storr → Kilt Rock → Quiraing → Fairy Glen)</name>
        <styleUrl>#route-day12</styleUrl>
        <description>Loop Trotternish, ~36min entre pontos extremos.</description>
        <LineString>
          <tessellate>1</tessellate>
          <coordinates>
            -5.4553,57.2408,0
            -6.1831,57.5071,0
            -6.1727,57.6113,0
            -6.2653,57.6436,0
            -6.3249,57.5824,0
            -5.4553,57.2408,0
          </coordinates>
        </LineString>
      </Placemark>

      <Placemark>
        <name>Day 13: Inverinate → Fort William (via Glenfinnan)</name>
        <styleUrl>#route-day13</styleUrl>
        <description>1h25 / 100km via A87 + A82.</description>
        <LineString>
          <tessellate>1</tessellate>
          <coordinates>
            -5.4553,57.2408,0
            -5.3667,57.1667,0
            -5.4318,56.8762,0
            -5.1052,56.8198,0
          </coordinates>
        </LineString>
      </Placemark>

      <Placemark>
        <name>Day 15: Fort William → Glencoe → Doune → Stirling → Linlithgow</name>
        <styleUrl>#route-day15</styleUrl>
        <description>2h39 / 185km direto via A82/A85/M9. Com 4 paradas longas, ~6h.</description>
        <LineString>
          <tessellate>1</tessellate>
          <coordinates>
            -5.1052,56.8198,0
            -4.9943,56.6593,0
            -4.0499,56.1852,0
            -3.9456,56.1229,0
            -3.9179,56.1388,0
            -3.6008,55.9789,0
          </coordinates>
        </LineString>
      </Placemark>

      <Placemark>
        <name>Day 17: Linlithgow → Blackness → Hopetoun → Edinburgh</name>
        <styleUrl>#route-day17</styleUrl>
        <description>35min / 31km direto. Com paradas: ~3h.</description>
        <LineString>
          <tessellate>1</tessellate>
          <coordinates>
            -3.6008,55.9789,0
            -3.5161,56.0060,0
            -3.4626,55.9956,0
            -3.1999,55.9486,0
          </coordinates>
        </LineString>
      </Placemark>

    </Folder>

  </Document>
