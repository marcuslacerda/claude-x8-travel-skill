        <styleUrl>#scenic</styleUrl>
        <Point><coordinates>11.7583,46.5092,0</coordinates></Point>
      </Placemark>

      <Placemark>
        <name>Lago di Carezza (Karersee)</name>
        <description>[Lago] Jun 25 (Thu) — Lago alpino com reflexo do Latemar e Catinaccio/Rosengarten. Parada no caminho para Sirmione. Despedida das Dolomitas</description>
        <styleUrl>#lago</styleUrl>
        <Point><coordinates>11.6014,46.4114,0</coordinates></Point>
