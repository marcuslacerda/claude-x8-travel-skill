<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Dolomites &amp; Slovenia Road Trip — Jun 2026</name>
    <description>The travelers — 20 days trip (Jun 8-27). Milan → Venezia → Slovenia → Cortina → Dolomites → Garda → MXP. Coordinates verified via Google Maps Geocoding API (Apr 2026). Distances/durations from OSRM.</description>

