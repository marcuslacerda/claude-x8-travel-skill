        <styleUrl>#trekking</styleUrl>
        <Point><coordinates>11.7792,46.6210,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Santa Maddalena</name>
        <description>[Viewpoint] Jun 24 (Wed) — Ponto mais fotografado das Dolomitas</description>
        <styleUrl>#viewpoint</styleUrl>
        <Point><coordinates>11.7173,46.6394,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Passo Gardena (2.136m)</name>
        <description>[Scenic] Jun 24 (Wed) — Sella Ronda icon. Paredes do Gruppo del Sella. Palco do Giro d'Italia</description>
        <styleUrl>#scenic</styleUrl>
        <Point><coordinates>11.8094,46.5500,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Rifugio Col Alt (Corvara)</name>
        <description>[Restaurante] Jun 24 (Wed) — Michelin-recognized. RESERVAR!</description>
        <styleUrl>#restaurante</styleUrl>
        <Point><coordinates>11.8862,46.5526,0</coordinates></Point>
      </Placemark>
      <Placemark>
