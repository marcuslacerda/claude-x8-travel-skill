    <Folder>
      <name>Pontos de Interesse</name>

      <!-- === Start/End === -->
      <Placemark>
        <name>Indie Campers MXP (Pickup/Return)</name>
        <description>Jun 9 (Tue): Pickup 16:00 | Jun 27 (Sat): Return 08:00</description>
        <styleUrl>#start-end</styleUrl>
        <Point><coordinates>8.7603,45.6197,0</coordinates></Point>
      </Placemark>

      <!-- === Venezia — Jun 9-10 (Tue-Wed) === -->
      <Placemark>
        <name>Venezia</name>
        <description>[City] Jun 9-10 (Tue-Wed) — San Marco, Palazzo Ducale, Rialto, Frari, Salute, Concerto Vivaldi</description>
        <styleUrl>#city</styleUrl>
        <Point><coordinates>12.3375,45.4408,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Camp: Fusina (Venezia)</name>
        <description>[Base Camp] Jun 9-10 (Tue-Wed) — 2 noites. Vaporetto direto a San Marco</description>
        <styleUrl>#basecamp</styleUrl>
        <Point><coordinates>12.2582,45.4208,0</coordinates></Point>
      </Placemark>

      <!-- === Venezia → Slovenia — Jun 11 (Thu) === -->
      <Placemark>
        <name>Cividale del Friuli (opcional)</name>
        <description>[UNESCO — opcional] Jun 11 (Thu) — Desvio +41 km / +45 min via Palmanova. Ponte do Diabo, Tempietto Longobardo sec. VIII</description>
        <styleUrl>#unesco</styleUrl>
        <Point><coordinates>13.4275,46.0959,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Postojna Cave</name>
        <description>[Caverna] Jun 11 (Thu) — 24km galerias, trem 3.7km, Proteus. Combo EUR47/pp</description>
        <styleUrl>#caverna</styleUrl>
        <Point><coordinates>14.2038,45.7830,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Predjama Castle</name>
        <description>[Castelo] Jun 11 (Thu) — Paredao 123m. 700+ anos. Combo Postojna</description>
        <styleUrl>#castelo</styleUrl>
        <Point><coordinates>14.1269,45.8158,0</coordinates></Point>
      </Placemark>

      <!-- === Slovenia — Bled Jun 11-14 (Thu-Sun) === -->
      <Placemark>
        <name>Camp: Bled</name>
        <description>[Base Camp] Jun 11-14 (Thu-Sun) — 3 noites. A beira do lago. ✅ Confirmado</description>
        <styleUrl>#basecamp</styleUrl>
        <Point><coordinates>14.0810,46.3614,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Lago Bled</name>
        <description>[Lago] Jun 12 (Fri) — Pletna boat, 99 degraus, sino dos desejos. 6km walk</description>
        <styleUrl>#lago</styleUrl>
        <Point><coordinates>14.0938,46.3636,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Bled Castle</name>
        <description>[Castelo] Jun 12 (Fri) — Sec. XI. Castelo mais antigo da Eslovenia. EUR19/pp</description>
        <styleUrl>#castelo</styleUrl>
        <Point><coordinates>14.1006,46.3699,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Vintgar Gorge</name>
        <description>[Natureza] Jun 12 (Fri) — 1.6km passarelas. Cascata Sum 16m. INGRESSO ONLINE!</description>
        <styleUrl>#natureza</styleUrl>
        <Point><coordinates>14.0857,46.3936,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Lago Bohinj</name>
        <description>[Lago] Jun 13 (Sat) — Maior lago glacial esloveno. Igreja St. John sec. XV</description>
        <styleUrl>#lago</styleUrl>
        <Point><coordinates>13.8594,46.2840,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Vogel Cable Car (1.535m)</name>
        <description>[Trekking] Jun 13 (Sat) — Panorama Triglav. EUR33/pp</description>
        <styleUrl>#trekking</styleUrl>
        <Point><coordinates>13.8354,46.2757,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Savica Waterfall</name>
        <description>[Waterfall] Jun 13 (Sat) (opcional) — 78m em 2 estagios. EUR3/pp</description>
        <styleUrl>#waterfall</styleUrl>
        <Point><coordinates>13.7968,46.2927,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Pokljuka Plateau</name>
        <description>[Natureza] Jun 14 (Sun) — REST DAY. Floresta, biatlo, gorge</description>
        <styleUrl>#natureza</styleUrl>
        <Point><coordinates>13.9236,46.3397,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Pericnik Waterfall</name>
        <description>[Waterfall] Jun 14 (Sun) — 52m, caminhar atras da cortina d'agua. Gratis</description>
        <styleUrl>#waterfall</styleUrl>
        <Point><coordinates>13.8938,46.4392,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Free Parking Kranjska Gora</name>
        <description>[Free Parking] Jun 14 (Sun) — Pernoite livre em Kranjska Gora. Posicionado para Vrsic Pass amanha cedo</description>
        <styleUrl>#basecamp</styleUrl>
        <Point><coordinates>13.7898,46.4859,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Zelenci Nature Reserve</name>
        <description>[Natureza] Jun 14 (Sun) — Nascentes esmeralda a 6C. Boardwalk 20 min</description>
        <styleUrl>#natureza</styleUrl>
        <Point><coordinates>13.7378,46.4926,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Kranjska Gora (opcional)</name>
        <description>[Vila — opcional] Jun 14 (Sun) — Vila alpina. Cafes, artesanato. Passagem para Vršič Pass</description>
        <styleUrl>#vila</styleUrl>
        <Point><coordinates>13.7898,46.4859,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Jasna Lake</name>
        <description>[Lago] Jun 15 (Mon) — Reflexo do Triglav. Estatua Zlatorog. 2h passeio matinal</description>
        <styleUrl>#lago</styleUrl>
        <Point><coordinates>13.7841,46.4740,0</coordinates></Point>
      </Placemark>

      <!-- === Slovenia — Soca Valley Jun 15-16 (Mon-Tue) === -->
      <Placemark>
        <name>Vrsic Pass (1.611m)</name>
        <description>[Scenic] Jun 15 (Mon) — 50 hairpin turns. Estrada mais alta da Eslovenia</description>
        <styleUrl>#scenic</styleUrl>
        <Point><coordinates>13.7431,46.4329,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Russian Chapel</name>
        <description>[Memorial] Jun 15 (Mon) — Curva 8. Memorial prisioneiros russos WWI</description>
        <styleUrl>#memorial</styleUrl>
        <Point><coordinates>13.7677,46.4426,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Great Soca Gorge</name>
        <description>[Natureza] Jun 15 (Mon) — Gargantas esmeralda. Walk 30 min</description>
        <styleUrl>#natureza</styleUrl>
        <Point><coordinates>13.6459,46.3372,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Bovec</name>
        <description>[City] Jun 15-16 (Mon-Tue) — Capital aventura da Eslovenia</description>
        <styleUrl>#city</styleUrl>
        <Point><coordinates>13.5517,46.3376,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Slap Kozjak</name>
        <description>[Waterfall] Jun 16 (Tue) — Cachoeira em gruta esmeralda, trilha curta ~1h. Gratis</description>
        <styleUrl>#waterfall</styleUrl>
        <Point><coordinates>13.5653,46.2648,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Rafting Rio Soca</name>
        <description>[Aventura] Jun 16 (Tue) — Classe II-III, EUR70/pp, 2-3h. Wetsuit incluido</description>
        <styleUrl>#aventura</styleUrl>
        <Point><coordinates>13.5600,46.2900,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Camp: Liza (Bovec)</name>
        <description>[Base Camp] Jun 15-16 (Mon-Tue) — Camp Liza, a beira do Rio Soca. 2 noites</description>
        <styleUrl>#basecamp</styleUrl>
        <Point><coordinates>13.5600,46.3308,0</coordinates></Point>
      </Placemark>

      <!-- === Soca → Cortina — Jun 17 (Wed) === -->
      <Placemark>
        <name>Lago del Predil</name>
        <description>[Lago] Jun 17 (Wed) — Lago alpino esmeralda na fronteira IT/SI. Walk 1h. Gratis</description>
        <styleUrl>#lago</styleUrl>
        <Point><coordinates>13.5651,46.4188,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Lago di Fusine</name>
        <description>[Lago] Jun 17 (Wed) — Hidden gem. Lagos glaciais + reflexo Mangart. Gratis</description>
        <styleUrl>#lago</styleUrl>
        <Point><coordinates>13.6706,46.4797,0</coordinates></Point>
      </Placemark>

      <!-- === Cortina Jun 17-19 (Wed-Fri) === -->
      <Placemark>
        <name>Cortina d'Ampezzo</name>
        <description>[City] Jun 17-19 (Wed-Fri) — Sede Olimpiadas Inverno 2026. Corso Italia</description>
        <styleUrl>#city</styleUrl>
        <Point><coordinates>12.1359,46.5378,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Camp: Dolomiti (Cortina)</name>
        <description>[Base Camp] Jun 17-19 (Wed-Fri) — 3 noites. Base Tre Cime e Sorapis</description>
        <styleUrl>#basecamp</styleUrl>
        <Point><coordinates>12.1450,46.5420,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Tre Cime di Lavaredo</name>
        <description>[Trekking] Jun 18 (Thu) — Circuit 10km, 3-4h. RESERVA ONLINE OBRIGATORIA!</description>
        <styleUrl>#trekking</styleUrl>
        <Point><coordinates>12.3028,46.6187,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Lago di Sorapis</name>
        <description>[Lago+Trek] Jun 19 (Fri) — 11.5km, 5-6h. Cabos de aco. Late June = trilha segura!</description>
        <styleUrl>#lago</styleUrl>
        <Point><coordinates>12.2235,46.5206,0</coordinates></Point>
      </Placemark>

      <!-- === Eastern Dolomites — transit Jun 20-21 (Sat-Sun) === -->
      <Placemark>
        <name>Bressanone (Brixen)</name>
        <description>[City] (optional stop, Jun 21 transit day)</description>
        <styleUrl>#city</styleUrl>
        <Point><coordinates>11.6525,46.7104,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Chiusa (Klausen)</name>
        <description>[Vila Medieval] Jun 22 (Mon) — No caminho Dobbiaco → Val Gardena. Vielas medievais. Monastero di Sabiona</description>
        <styleUrl>#vila</styleUrl>
        <Point><coordinates>11.5641,46.6392,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Lago di Braies</name>
        <description>[Lago] Jun 20 (Sat) — No caminho Cortina → Olympia. Perola das Dolomitas. Circuit 3.5km + barco</description>
        <styleUrl>#lago</styleUrl>
        <Point><coordinates>12.0854,46.6943,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Camp: Olympia (Dobbiaco)</name>
        <description>[Base Camp] Jun 20–22 (Sat–Mon, 2 noites) — Camping Olympia ★★★★, Category A Zone 200. Wellness: Finnish sauna, steam bath, infrared sauna, pools. Self-service laundry. ✅ Reservado</description>
        <styleUrl>#basecamp</styleUrl>
        <Point><coordinates>12.1937,46.7344,0</coordinates></Point>
      </Placemark>

      <!-- === Western Dolomites Jun 21-25 (Sun-Thu) === -->
      <Placemark>
        <name>Seceda Ridgeline (2.519m)</name>
        <description>[Trekking] Jun 22 (Mon) — Cable car EUR74/pp RT. Hike 10km, 3-4h. Late June = trilha limpa!</description>
        <styleUrl>#trekking</styleUrl>
        <Point><coordinates>11.7049,46.5598,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Camp: Val Gardena</name>
        <description>[Base Camp] Jun 22-25 (Mon-Thu) — 3 noites</description>
        <styleUrl>#basecamp</styleUrl>
        <Point><coordinates>11.6500,46.5600,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Alpe di Siusi (Compatsch)</name>
        <description>[Trekking] Jun 23 (Tue) — Maior prado alpino (56 km2). Late June = FULL BLOOM!</description>
        <styleUrl>#trekking</styleUrl>
        <Point><coordinates>11.6170,46.5412,0</coordinates></Point>
      </Placemark>
      <Placemark>
